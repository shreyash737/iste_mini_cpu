    %vpi_call/w 3 26 "$display", "time\011a\011b\011sum\011carry" {0 0 0};
    %vpi_call/w 3 27 "$monitor", "%0dns\011%b\011%b\011%b\011%b", $time, v0x594c26aa12a0_0, v0x594c26aa1360_0, v0x594c26aa1530_0, v0x594c26aa1430_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
