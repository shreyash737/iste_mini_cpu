    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x594c26aa1360_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x594c26aa12a0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x594c26aa1360_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x594c26aa12a0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x594c26aa1360_0, 0, 1;
